generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Project {
  id           String   @id @default(uuid())
  title        String
  description  String
  technologies String[]
  githubUrl    String?
  liveUrl      String?
  image        String?
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Skill {
  id         String   @id @default(uuid())
  name       String
  category   String
  percentage Int      @default(0)
  icon       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Resume {
  id        String   @id @default(uuid())
  title     String
  fileUrl   String
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
}
