{
  "compilerOptions": {
    // Output
    "outDir": "./dist",

    // Environment — node16 pair is required together; no deprecation warnings
    "module": "node16",
    "moduleResolution": "node16",
    "target": "es2020",
    "lib": ["es2020"],
    "types": ["node"],

    // Emit
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Strict — all enabled, no hacks
    "strict": true,
    "noUncheckedIndexedAccess": true,

    // Module Interop
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,

    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": false
  },
  "include": ["src/**/*", "api/**/*", "prisma/**/*"],
  "exclude": ["node_modules", "dist"]
}
